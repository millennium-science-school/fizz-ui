{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ESNext"],
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": [
    "scripts/**/*",
    "*.config.ts",
    "*.config.mts",
    "packages/*/vite.config.ts",
    "packages/*/preview/vite.config.ts"
  ],
  "exclude": ["**/dist"]
}
